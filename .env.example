# ==============================================================================
# AREX - Environment Configuration Example
# ==============================================================================
# Copy this file to '.env' and modify the values for your local environment.

# ------------------------------------------------------------------------------
# PostgreSQL Database Settings
# ------------------------------------------------------------------------------
# The username for the local PostgreSQL database
POSTGRES_USER=postgres

# The password for the local PostgreSQL database
POSTGRES_PASSWORD=dev_password

# The name of the database created on startup
POSTGRES_DB=arex_db

# Connection string for SQLAlchemy (in-cluster fallback if not using localhost)
# Used by backend service to connect to postgres
DATABASE_URL=postgresql://postgres:dev_password@postgres:5432/arex_db

# ------------------------------------------------------------------------------
# Qdrant Vector DB Settings
# ------------------------------------------------------------------------------
# URL for the Qdrant service inside the docker network
QDRANT_URL=http://qdrant:6333

# ------------------------------------------------------------------------------
# Security & JWT Configuration
# ------------------------------------------------------------------------------
# Key used to sign JWT access tokens. Change this to a secure random string in production!
JWT_SECRET=super_secret_jwt_signing_key_change_me_in_production_123456

# JWT token expiration time in minutes (default is 1 day)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ------------------------------------------------------------------------------
# AI Orchestration (LLM & Embeddings)
# ------------------------------------------------------------------------------
# Inference API provider key (e.g. Fireworks API or local ROCm host API)
# Required for running the Qwen3 8B agentic intelligence layer.
LLM_API_KEY=your_llm_provider_api_key_here

# LLM API Base URL (if using a self-hosted local model or custom endpoint, e.g. vLLM/ROCm)
LLM_API_BASE=https://api.fireworks.ai/inference/v1

# Embeddings API Key (if different, e.g. for HuggingFace/Fireworks/OpenAI)
EMBEDDING_API_KEY=your_embedding_api_key_here

# ------------------------------------------------------------------------------
# Jira Integration
# ------------------------------------------------------------------------------
# Base URL for your Jira Cloud instance (e.g. https://your-domain.atlassian.net)
JIRA_URL=
# Atlassian user account email
JIRA_EMAIL=
# Atlassian API Token generated from Atlassian Account Settings
JIRA_API_TOKEN=
# Jira Project Key (e.g. AREX) where tickets will be created
JIRA_PROJECT_KEY=

