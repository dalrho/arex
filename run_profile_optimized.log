        \"type\": \"string\"\n        },\n        \"department\": {\n          \"title\": \"Department\",\n          \"type\": \"string\"\n        },\n        \"priority\": {\n          \"default\": \"Medium\",\n          \"title\": \"Priority\",\n          \"type\": \"string\"\n        }\n      },\n      \"required\": [\n        \"title\",\n        \"description\",\n        \"department\"\n      ],\n      \"title\": \"TaskItem\",\n      \"type\": \"object\"\n    }\n  },\n  \"properties\": {\n    \"requires_tasks\": {\n      \"title\": \"Requires Tasks\",\n      \"type\": \"boolean\"\n    },\n    \"tasks\": {\n      \"items\": {\n        \"$ref\": \"#/$defs/TaskItem\"\n      },\n      \"title\": \"Tasks\",\n      \"type\": \"array\"\n    }\n  },\n  \"required\": [\n    \"requires_tasks\",\n    \"tasks\"\n  ],\n  \"title\": \"ImplementationAgentOutput\",\n  \"type\": \"object\"\n}"
